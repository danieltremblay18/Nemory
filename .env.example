# OPTIONAL for local development.
#
# The app already runs locally with safe dummy defaults (see config.py), so you
# do NOT need a .env file at all. The variables below are commented out on
# purpose: uncomment one only if you want to override it locally.
#
# In PRODUCTION you do not use this file — set these as real environment
# variables (e.g. in the PythonAnywhere WSGI file). See the README.
#
# Copy this file to .env to use it. Never commit the real .env.

# Flask session signing key. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=

# Single-user login password (plain text here; hashed at runtime).
# NEMORY_PASSWORD=
