# OPTIONAL for local development: the app already runs with safe dummy defaults
# (see config.py), so you don't need a .env locally. Create one only if you want
# a custom local password. In PRODUCTION these MUST be set to real secret values.
# Copy to .env and fill in. Never commit the real .env.

# Flask session signing key. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# Single-user login password (plain text here; hashed at runtime).
NEMORY_PASSWORD=change-me
